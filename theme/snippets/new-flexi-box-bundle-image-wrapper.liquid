{% comment %}New Flexi Box Image Wrapper - Metafield Images First{% endcomment %}
{% comment %}
{%- render 'new-flexi-box-bundle-image-wrapper', product_flexi: product_flexi, variant: variant, item_index: item_index, section: section -%}
{% endcomment %}

{% if section.settings.show-multiple-image %}
  {% assign max_images = 1 %}
{% else %}
  {% assign max_images = 1 %}
{% endif %}

{% capture slides %}
  {%- comment -%}Priority 1: Check for metafield images{%- endcomment -%}
  {%- assign metafield_image = product_flexi.metafields.custom.png_for_crazy_deals.value -%}
  
  {% if metafield_image != blank %}
    {%- comment -%}Use metafield image as primary source{%- endcomment -%}
    <div class="grid-item slider-slide">
      {% if item_index == 1 or item_index == 2 or item_index == 3 or item_index == 4 %}
        <img 
          src="{{ metafield_image | image_url: width: 300 }}" 
          alt="{{ product_flexi.title }}" 
          loading="eager" 
          fetchpriority="high" 
          style="width: 100%; height: auto; object-fit: cover;">
      {% else %}
        <img 
          src="{{ metafield_image | image_url: width: 250 }}" 
          alt="{{ product_flexi.title }}" 
          loading="lazy" 
          fetchpriority="low" 
          style="width: 100%; height: auto; object-fit: cover;">
      {% endif %}
    </div>
    {% assign image_count = 1 %}

  {% elsif product_flexi.has_only_default_variant or variant.featured_image == blank %}
    {%- comment -%}Priority 2: Fallback to product images{%- endcomment -%}
    {% for image in product_flexi.images limit: max_images %}
      <div class="grid-item slider-slide">
        {% if forloop.index == 1 %}
          {% if item_index == 1 or item_index == 2 or item_index == 3 or item_index == 4 %}
            {{ image | image_url: width: 300 | image_tag: loading: 'eager', fetchpriority: 'high' }}
          {% else %}
            {{ image | image_url: width: 250 | image_tag: loading: 'lazy', fetchpriority: 'low' }}
          {% endif %}
        {% else %}
          {{ image | image_url: width: 250 | image_tag: loading: 'lazy', fetchpriority: 'low' }}
        {% endif %}
      </div>
      {% assign image_count = image_count | plus: 1 %}
    {% endfor %}

  {% else %}
    {%- comment -%}Priority 3: Fallback to variant/product image{%- endcomment -%}
    {%- comment -%}1. First slide = variant image{%- endcomment -%}
    <div class="grid-item slider-slide">
      {{ variant.featured_image | image_url: width: 500 | image_tag: loading: 'lazy', fetchpriority: 'low' }}
    </div>
    {% assign image_count = 1 %}

    {%- comment -%}2. Next slides = product images from 2nd image onwards{%- endcomment -%}
    {% for image in product_flexi.images %}
      {% if forloop.index > 1 and image_count < max_images %}
        {% if image != variant.featured_image %}
          <div class="grid-item slider-slide">
            {{ image | image_url: width: 500 | image_tag: loading: 'lazy', fetchpriority: 'low' }}
          </div>
          {% assign image_count = image_count | plus: 1 %}
        {% endif %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endcapture %}

<div class="product-images-slider">
  <div class="grid-col slider-wrapper" role="list">
    {{ slides }}
  </div>

  {% if section.settings.show-multiple-image %}
    <div class="slider-pagination">
      {% for i in (1..max_images) %}
        {% if i <= image_count %}
          <button
            class="slider-dot{% if i == 1 %} active{% endif %}"
            aria-label="Go to slide {{ i | minus: 1 }}"
            data-index="{{ i | minus: 1 }}"
            type="button"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>

{% if section.settings.show-multiple-image %}
  <script>
    function initProductImagesSlider(component) {
      const slider = component.querySelector('.slider-wrapper');
      const dots = component.querySelectorAll('.slider-dot');
      const slides = slider.querySelectorAll('.slider-slide');

      // Dot click event
      dots.forEach(function(dot) {
        dot.addEventListener('click', function (e) {
          e.preventDefault();
          const idx = parseInt(this.getAttribute('data-index'), 10);
          if (slides[idx]) {
            const slideLeft = slides[idx].offsetLeft;
            slider.scrollTo({
              left: slideLeft,
              behavior: 'smooth'
            });
          }
        });
      });

      // Update active dot on scroll
      slider.addEventListener('scroll', function () {
        const sliderRect = slider.getBoundingClientRect();
        let minDiff = Infinity;
        let activeIdx = 0;

        slides.forEach((slide, idx) => {
          const rect = slide.getBoundingClientRect();
          const diff = Math.abs(rect.left - sliderRect.left);
          if (diff < minDiff) {
            minDiff = diff;
            activeIdx = idx;
          }
        });

        dots.forEach((dot, idx) => {
          dot.classList.toggle('active', idx === activeIdx);
        });
      });
    }

    // Initialize any sliders present on page load
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('.product-images-slider').forEach(initProductImagesSlider);
    });
  </script>
{% endif %}

<style>
  .product-images-slider {
    position: relative;
    display: block;
  }

  .product-images-slider .slider-pagination {
    display: none;
  }

  .slider-wrapper {
    position: relative;
    flex-wrap: inherit;
    overflow-y: hidden;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none !important;
    border-radius: 4px;
  }

  .grid-col {
    display: flex;
    margin-bottom: 1rem;
    padding: 0;
    list-style: none;
    column-gap: 0.5rem;
  }

  .slider-wrapper .slider-slide {
    margin-bottom: 0;
    padding-bottom: 0;
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  .grid-col .grid-item {
    max-width: 100%;
    width: 100%;
  }

  .slider-slide img {
    width: 100%;
    height: auto;
  }

  .slider-pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .slider-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: #ccc;
    cursor: pointer;
    transition: background 0.2s;
    padding: 0;
  }

  .slider-dot.active {
    background: #333;
  }

  @media screen and (min-width: 750px) {
    .slider-dot {
      width: 6px;
      height: 6px;
    }
  }
</style>
