<div class="parent-tab">
    <div class="child-tabs">
      {% if product.description %}
        <button class="tabs-button" data-tab="description"> DESCRIPTION </button>
      {% endif %}
      {% if product.metafields.custom.product_ingredients %}
        <button class="tabs-button" data-tab="notes"> NOTES </button>
      {% endif %}
      {% if product.metafields.custom.product_meta_coms.value != blank %}
        <button class="tabs-button" data-tab="product_meta_coms">Meta Coms </button>
      {% endif %}
      {% if product.metafields.custom.product_faq_content %}
        <button class="tabs-button" data-tab="FAQ"> FAQ </button>
      {% endif %}
      {% if product.metafields.custom.how_to_use %}
        <button class="tabs-button" data-tab="how_to_use"> How To Use </button>
      {% endif %}
      {% if product.metafields.custom.key_benefits %}
        <button class="tabs-button" data-tab="key_benefits"> KEY BENEFITS </button>
      {% endif %}
      {% if product.metafields.custom.all_ingredients %}
        <button class="tabs-button" data-tab="all_ingredients"> ALL INGREDIENTS </button>     
      {% endif %}
      
    </div>
    <div class="child-content">
      {% if product.description %}
    <div id="description" class="tabcontent">
      <div class="ingredients-tab-wrapper">
         {{ product.description }}
      </div>
    </div>
    {% endif %}
    {% if product.metafields.custom.product_ingredients %}
    <div id="notes" class="tabcontent">
      <div class="ingredients-tab-wrapper">
        {% render 'custom-product-ingredients-metaobject' %}
      </div>
    </div>
    {% endif %}
    
    {% if product.metafields.custom.product_meta_coms.value != blank %}
    <div id="product_meta_coms" class="tabcontent">
      <div class="meta-coms-tab-wrapper">
        {% render 'meta_coms_with_description' %}
      </div>
    </div>
    {% endif %}

    {% if product.metafields.custom.product_faq_content %}
    <div id="FAQ" class="tabcontent">
      <div class="product-faq-content-new">
        {{ product.metafields.custom.product_faq_content }}
      </div>
    </div>
    {% endif %}
    {% if product.metafields.custom.how_to_use %}
    <div id="how_to_use" class="tabcontent">
      <div class="product-faq-content-new">
        {{ product.metafields.custom.how_to_use }}
      </div>
    </div>
    {% endif %}
    {% if product.metafields.custom.key_benefits %}
    <div id="key_benefits" class="tabcontent">
      <div class="product-faq-content-new">
        {{ product.metafields.custom.key_benefits }}
      </div>
    </div>
    {% endif %}
     {% if product.metafields.custom.all_ingredients %}
    <div id="all_ingredients" class="tabcontent">
      <div class="product-faq-content-new">
        {{ product.metafields.custom.all_ingredients }}
      </div>
    </div>
    {% endif %}
  </div>
</div>
      <style>
        .parent-tab .product-ingredients ul{
          display:block;
        }
        .parent-tab{
            background-color: antiquewhite;
        }

       .parent-tab li.product-ingredients-item.grid__item.slider__slide.center {
         width: 100%;
       }
        .parent-tab li.new-pdp-css {
          display: flex;
        }
        .new-pdp-css .ingredient-img-wrapper {
         width: 35%;
         align-items: baseline;
        }
          .parent-tab .page-width{
          padding:0;
        }
@media(min-width:750px){
  .parent-tab .grid--2-col .grid__item{
          max-width:100%!important;
          width:100%!important;
        }
}
.child-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    width: auto;
    background-color: #FFFFFF;
    padding: 0;
    margin: 0;
}
.child-tabs button {
    flex: 1 1 0;
    background: #FFFFFF;
    border: solid 1px #EAEAEA;
    outline: none;
    padding: 10px 15px;
    font-weight: bold;
    cursor: pointer;
    transition: background 0.3s;
    color: black;
}
        .child-tabs button:hover{
            background: #74aedd;
        }
        .child-tabs button.active{
            background: #fff;
        }
        

        .tabcontent{
            background:#F4F4F4;
            padding:1.5rem;
            display:none;
        }
        .ingredient-content {
    width: 90%;
    text-align: left;
    padding-left: 15px;
    line-height: 1.3;
    font-size: 16px;
}
        .new-pdp-css .ingredient-img-wrapper {
    width: 20%;
    align-items: baseline;
}


        @media screen and (max-width: 600px) {
    .child-tabs {
        overflow-x: auto;
        flex-wrap: nowrap;
    }

    .child-tabs button {
        flex: 0 0 auto;
        white-space: nowrap;
    }
}

        /* metacoms css starts here  */
       .parent-tab .meta-coms-container{
         display:block;
         margin:0!important;
       }

       .parent-tab .meta-coms-img-container{
             display: flex;
           background:#F4F4F4;
         padding:0;
       }
        .parent-tab .meta-coms-text{
          display:block;
          text-align:left;
              width: 80%;
        }
        .parent-tab .metacoms-image {
    width: 20%;
    display: flex;
    justify-content:center;
    align-items:center;
}

.parent-tab .metacoms-image img {
    width: 100%!important;
}
.parent-tab .child-tabs button.active {
    background: #F4F4F4;
    color: #000000;
}

  .tabs-button {
    border-radius: 3px;
}

.tabcontent {
    height: 40rem;
    overflow-y: auto;
}

.meta-coms-tab-wrapper {
    height: 37rem;
    display: flex;
}
        
.parent-tab p.meta-coms-text-heading{
    font-size: 16px!important;
}
        .parent-tab .meta-coms-container {
    display: inline-grid;
    justify-content: space-between;
    margin: 0!important;
}
         .parent-tab p.meta-coms-text-para{
         font-size:13px; 
           font-weight:100;
        }
 /* Faq CSS starts here */
        .product-faq-content-new {
    overflow-y: auto;
    height: 35rem;
}
.parent-tab .child-content {
  display: none;
}

.parent-tab.expanded .child-content {
  display: block;
}
    </style>

<script>
    
    const tabButtons = document.querySelectorAll('.tabs-button');
  const parentTab = document.querySelector('.parent-tab');
  let activeTab = null;

  for (let i = 0; i < tabButtons.length; i++) {

    tabButtons[i].addEventListener('click', function () {

      const tabName = this.dataset.tab;
      const tabcontent = document.getElementById(tabName);

      const allTabContent = document.querySelectorAll('.tabcontent');
      const allTabButtons = document.querySelectorAll('.tabs-button');

      // If clicking same tab again → collapse
      if (activeTab === tabName) {
        allTabContent.forEach(el => el.style.display = "none");
        allTabButtons.forEach(btn => btn.classList.remove('active'));
        parentTab.classList.remove('expanded');
        activeTab = null;
        return;
      }

      // Hide all tabs
      allTabContent.forEach(el => el.style.display = "none");
      allTabButtons.forEach(btn => btn.classList.remove('active'));

      // Show selected tab
      tabcontent.style.display = "block";
      this.classList.add('active');

      parentTab.classList.add('expanded');

      activeTab = tabName;

    });

  }

    //document.querySelector('.tabs-button').click();
</script>