{% assign product_item = collection.metafields.custom.bundle_product.value %}
{% assign product_limit = collection.metafields.custom.product_limit | default: 3 %}

{% if product_item != blank %}

<div id="bundle-wrapper" data-limit="{{ product_limit }}">

  <!-- ================= TOP BAR ================= -->
  {% if section.settings.show_top_strip %}
  <div class="bundle-top-bar">
    <p class="bundle-title">{{ product_item.title }}</p>

    <div class="bundle-progress">
      <div class="line"></div>
      <div class="circle cart-count">0</div>
    </div>

    <p class="bundle-subtitle">
      Select any {{ product_limit }} Perfumes
    </p>
  </div>
  {% endif %}

  <!-- ================= BOTTOM BAR ================= -->
  {% if section.settings.show_bottom_strip %}
  <div class="bundle-sticky-bar">
    <div class="bundle-left">
      {% comment %} <img src="{{ product_item.featured_image | image_url: width: 100 }}"> {% endcomment %}
      <span class="bundle-title">{{ product_item.title }}</span>
    </div>

    <div class="bundle-right">
      <span class="bundle-price">
        Total: {{ product_item.price | money }}
      </span>

      <a href="javascript:void(0)" class="bundle-buy-btn" style="display:none;">
        {{ section.settings.buy_now_text }}
      </a>
    </div>
  </div>
  {% endif %}

</div>

{% endif %}
<style>
  .bundle-buy-btn {
  display: none; /* fixed typo */
}

/* TOP BAR */
.bundle-top-bar {
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 9999;
  background: #f5f5f5;
  border-bottom: 1px solid #e5e5e5;
  text-align: center;
  padding: 16px 0;
}

.bundle-title {
  font-size: 16px;
  font-weight: 500;
}

.bundle-subtitle {
  font-size: 14px;
  color: #444;
}

.bundle-progress {
  position: relative;
  width: 220px;
  margin: 8px auto;
}

.bundle-progress .line {
  height: 2px;
  background: #000;
}

.bundle-progress .circle {
  position: absolute;
  top: -10px;
  left: 50%;
  transform: translateX(-50%);
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #fff;
  border: 2px solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bundle-progress .circle.active {
  background: #2ecc71;
  border-color: #2ecc71;
  color: #fff;
}

/* BOTTOM BAR */
.bundle-sticky-bar {
  position: fixed;
  bottom: 0;
  width: 100%;
  background: #f5f5f5;
  border-top: 1px solid #e5e5e5;
  padding: 12px 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 9999;
}

.bundle-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.bundle-left img {
  width: 50px;
  height: 50px;
  border-radius: 4px;
}

.bundle-right {
  display: flex;
  align-items: center;
  gap: 20px;
}

.bundle-buy-btn {
  background: #000;
  color: #fff;
  padding: 10px 24px;
  border-radius: 10px;
  text-decoration: none;
}
@media screen and (min-width: 749px) {
  .bundle-left {
    padding-left: 154px;
    margin-left: 20px;
  }
  .bundle-sticky-bar {
    padding-right: 196px;
  }
  
}
.bundle-buy-btn {
  white-space: nowrap;       /* 🔥 prevents line break */
  display: inline-block;     /* ensures proper width handling */
  text-align: center;
}

/* Optional: improve mobile spacing */
@media screen and (max-width: 480px) {
  .bundle-right {
    gap: 10px;
  }

  .bundle-buy-btn {
    padding: 8px 16px;  /* slightly smaller padding */
    font-size: 14px;    /* reduce text size if needed */
  }
}
</style>
<script>
function getStoredVariants() {
  return JSON.parse(localStorage.getItem("bundle_variants") || "[]");
}

function setStoredVariants(variants) {
  localStorage.setItem("bundle_variants", JSON.stringify(variants));
}

function clearStoredVariants() {
  localStorage.removeItem("bundle_variants");
}

document.addEventListener("DOMContentLoaded", () => {

  const wrapper = document.getElementById("bundle-wrapper");
  if (!wrapper) return;

  const limit = parseInt(wrapper.dataset.limit);
  const cartCountEl = document.querySelector(".cart-count");
  const bundleBtn = document.querySelector(".bundle-buy-btn");

  /* ================= UPDATE UI ================= */
  function updateUI() {
    const variants = getStoredVariants();
    const count = variants.length;

    // Count UI
    if (cartCountEl) {
      if (count >= limit) {
        cartCountEl.innerText = "✓";
        cartCountEl.classList.add("active");
      } else {
        cartCountEl.innerText = count;
        cartCountEl.classList.remove("active");
      }
    }

    // Buy button
    if (bundleBtn) {
      bundleBtn.style.display = count >= limit ? "block" : "none";
    }

    // Button states
    document.querySelectorAll(".add-to-cart-custom").forEach(btn => {
      const id = btn.dataset.variantId;

      if (variants.includes(id)) {
        btn.innerText = "Remove";
        btn.dataset.inCart = "true";
      } else {
        btn.innerText = "Add to cart";
        btn.dataset.inCart = "false";
      }
    });
  }

  /* ================= CLICK HANDLER ================= */
  document.querySelectorAll(".add-to-cart-custom").forEach(btn => {

    btn.addEventListener("click", (e) => {
      e.preventDefault();

      const id = btn.dataset.variantId;
      let variants = getStoredVariants();

      if (!id) return;

      if (variants.includes(id)) {
        // REMOVE
        variants = variants.filter(v => v != id);
      } else {
        // ADD
        if (variants.length >= limit) {
          alert(`You can only select ${limit} products`);
          return;
        }
        variants.push(id);
      }

      setStoredVariants(variants);
      updateUI();
    });

  });

  /* ================= BUY NOW ================= */
  if (bundleBtn) {
    bundleBtn.addEventListener("click", async () => {

      const variants = getStoredVariants();

      if (variants.length < limit) {
        alert(`Please select ${limit} products`);
        return;
      }
      console.log("variants", variants);
      try {
        await fetch("/cart/add.js", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            items: variants.map(id => ({
              id: id,
              quantity: 1
            }))
          })
        });

        clearStoredVariants();
        setTimeout(() => {
          window.location.href = "/checkout";
        }, 1000);

      } catch (err) {
        console.error(err);
        alert("Error adding bundle");
      }
    });
  }

  /* ================= INIT ================= */
  updateUI();

});
</script>

{% schema %}
{
  "name": "Bundle Sticky",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_top_strip",
      "label": "Enable Top Strip",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bottom_strip",
      "label": "Enable Bottom Strip",
      "default": true
    },
    {
      "type": "text",
      "id": "buy_now_text",
      "label": "Buy Now Button Text",
      "default": "BUY NOW"
    }
  ],
  "presets": [
    {
      "name": "Bundle Sticky Combined"
    }
  ]
}
{% endschema %}