{% assign product_item = collection.metafields.custom.bundle_product.value %}

{% if product_item != blank %}
  {% assign is_bundle_in_cart = false %}

  {% for item in cart.items %}
    {% if item.product.id == product_item.id %}
      {% assign is_bundle_in_cart = true %}
    {% endif %}
  {% endfor %}

  <div class="bundle-sticky-bar">
    <div class="bundle-left">
      <img src="{{ product_item.featured_image | image_url: width: 100 }}">
      <span class="bundle-title">{{ product_item.title }}</span>
    </div>

    <div class="bundle-right">
      <span class="bundle-price"> Total: ₹{{ product_item.price | money_without_currency }}/- </span>

      {% if is_bundle_in_cart %}
        <a href="/checkout" class="bundle-buy-btn">
          {{ section.settings.buy_now_text }}
        </a>
      {% endif %}
    </div>
  </div>
{% endif %}

<style>
  .bundle-sticky-bar {
    position: fixed;
    bottom: 0;
    width: 100%;
    background: #f5f5f5;
    border-top: 1px solid #e5e5e5;
    padding: 12px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 9999;
  }

  /* LEFT SIDE */
  .bundle-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .bundle-left img {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 4px;
  }

  .bundle-title {
    font-size: 18px;
    font-weight: 500;
    color: #222;
  }

  /* RIGHT SIDE */
  .bundle-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .bundle-price {
    font-size: 18px;
    font-weight: 600;
    color: #000;
  }

  /* BUTTON */
  .bundle-buy-btn {
    background: #000;
    color: #fff;
    padding: 12px 28px;
    border-radius: 12px;
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 1px;
    transition: 0.3s;
  }

  .bundle-buy-btn:hover {
    opacity: 0.85;
  }
</style>
<script>document.addEventListener("DOMContentLoaded", function () {
  // Run only on BYOB collection

  const buttons = document.querySelectorAll(".button");

  buttons.forEach((btn) => {
    btn.addEventListener("click", async function () {
      const variantId = this.dataset.variantId;
      const inCart = this.dataset.inCart === "true";

      try {
        if (!inCart) {
          // ADD TO CART
          await fetch("/cart/add.js", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              id: variantId,
              quantity: 1,
            }),
          });

          this.innerText = "Remove";
          this.dataset.inCart = "true";

        } else {
          // GET CART FIRST (to find line item key)
          const cart = await fetch("/cart.js").then((res) => res.json());

          const item = cart.items.find(
            (i) => i.variant_id == variantId
          );

          if (item) {
            await fetch("/cart/change.js", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({
                id: item.key,
                quantity: 0,
              }),
            });
          }

          this.innerText = "Add to cart";
          this.dataset.inCart = "false";
        }

      } catch (error) {
        console.error("Cart error:", error);
      }
    });
  });
});
document.addEventListener("DOMContentLoaded", async function () {
 

  const cart = await fetch("/cart.js").then((res) => res.json());

  document.querySelectorAll(".button").forEach((btn) => {
    const variantId = btn.dataset.variantId;

    const exists = cart.items.some(
      (item) => item.variant_id == variantId
    );

    if (exists) {
      btn.innerText = "Remove";
      btn.dataset.inCart = "true";
    }
  });
});
</script>

{% schema %} 
{
  "name": "Bundle Sticky Strip",
  "settings": [
    {
      "type": "text",
      "id": "buy_now_text",
      "label": "Buy Now Button Text",
      "default": "BUY NOW"
    }
  ],
  "presets": [
    {
      "name": "Collection – Strip",
      "category": "Collection"
    }
  ]
}
{% endschema %}
